---
// ============================================================
// TECH TABLE — Stack tecnológico por categorías
// Formato tabla: Categoría | Tecnologías
// ============================================================
interface TechRow {
  category: string;
  icon: string;
  technologies: string[];
}

// Mapeo de tecnologías: [nombreDevicon, tieneVersionPlain]
const techMap: Record<string, [string, boolean]> = {
  'HTML5': ['html5', true],
  'HTML': ['html5', true],
  'CSS3': ['css3', true],
  'CSS': ['css3', true],
  'JavaScript': ['javascript', true],
  'JS': ['javascript', true],
  'TypeScript': ['typescript', true],
  'TS': ['typescript', true],
  'Python': ['python', true],
  'Flask': ['flask', false],
  'Django': ['django', true],
  'PHP': ['php', true],
  'MySQL': ['mysql', true],
  'SQLite': ['sqlite', true],
  'PostgreSQL': ['postgresql', true],
  'Postgres': ['postgresql', true],
  'Astro': ['astro', true],
  'React': ['react', true],
  'Vue': ['vue', true],
  'Next.js': ['nextjs', true],
  'TailwindCSS': ['tailwindcss', false],
  'Tailwind': ['tailwindcss', false],
  'Bootstrap': ['bootstrap', true],
  'Laravel': ['laravel', true],
  'Node.js': ['nodejs', true],
  'Node': ['nodejs', true],
  'Linux': ['linux', true],
  'Docker': ['docker', true],
};

// Función para obtener el icono de Devicon (versión original con colores)
function getDeviconUrl(tech: string): string {
  const mapped = techMap[tech];
  if (!mapped) {
    return `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${tech.toLowerCase()}/${tech.toLowerCase()}-original.svg`;
  }
  const [iconName, hasPlain] = mapped;
  const version = hasPlain ? 'original' : 'original';
  return `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${iconName}/${iconName}-${version}.svg`;
}

const rows: TechRow[] = [
  {
    category: 'Desarrollo Backend',
    icon: '⚙️',
    technologies: ['Python', 'PHP', 'MySQL', 'SQLite', 'PostgreSQL', 'Node.js', 'Next.js'],
  },
  {
    category: 'Desarrollo Frontend',
    icon: '🎨',
    technologies: ['JavaScript', 'HTML5', 'CSS3', 'Astro', 'TailwindCSS', 'Bootstrap', 'React'],
  },
  {
    category: 'Infraestructura',
    icon: '🖥️',
    technologies: ['Linux', 'Docker'],
  },
];
---

<section id="stack" class="py-12 md:py-16">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Encabezado -->
    <div class="text-center mb-12 scroll-reveal">
      <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #3b82f6;">Stack Tecnológico</p>
      <h2 class="text-3xl md:text-4xl font-bold" style="color: #f8fafc;">
        Mi caja de herramientas
      </h2>
    </div>

    <!-- Tabla (desktop) -->
    <div class="hidden md:block scroll-reveal">
      <div class="rounded-2xl overflow-hidden border" style="border-color: #1e293b;">
        <table class="w-full text-sm">
          <thead>
            <tr style="background-color: #0f172a; border-bottom: 1px solid #1e293b;">
              <th class="text-left px-6 py-4 font-semibold" style="color: #64748b;">Categoría</th>
              <th class="text-left px-6 py-4 font-semibold" style="color: #64748b;">Tecnologías</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row, i) => (
              <tr
                style={`background-color: ${i % 2 === 0 ? '#0f172a' : '#0b1120'}; border-bottom: 1px solid #1e293b;`}
              >
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <span class="text-lg">{row.icon}</span>
                    <span class="font-medium" style="color: #f8fafc;">{row.category}</span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <div class="flex flex-wrap gap-3">
                    {row.technologies.map((tech) => (
                      <div 
                        class="flex items-center gap-2 px-3 py-1.5 rounded-full border"
                        style="background-color: #1e293b; border-color: #334155;"
                        title={tech}
                      >
                        <img 
                          src={getDeviconUrl(tech)} 
                          alt={tech}
                          class="w-5 h-5 object-contain"
                          loading="lazy"
                        />
                        <span class="text-xs text-slate-300 font-medium">{tech}</span>
                      </div>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile: cards -->
    <div class="md:hidden space-y-4">
      {rows.map((row, i) => (
        <div 
          class="rounded-xl p-4 border scroll-reveal" 
          style={`background-color: ${i % 2 === 0 ? '#0f172a' : '#0b1120'}; border-color: #1e293b;`}
        >
          <div class="flex items-center gap-2 mb-3">
            <span class="text-lg">{row.icon}</span>
            <span class="font-semibold text-sm" style="color: #f8fafc;">{row.category}</span>
          </div>
          <div class="flex flex-wrap gap-2">
            {row.technologies.map((tech) => (
              <div 
                class="flex items-center gap-2 px-3 py-1.5 rounded-full border"
                style="background-color: #1e293b; border-color: #334155;"
                title={tech}
              >
                <img 
                  src={getDeviconUrl(tech)} 
                  alt={tech}
                  class="w-5 h-5 object-contain"
                  loading="lazy"
                />
                <span class="text-xs text-slate-300 font-medium">{tech}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>