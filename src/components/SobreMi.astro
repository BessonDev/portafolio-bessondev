---
import profile from '../data/profile.json';
---

<section id="sobre-mi" class="section-padding">
  <div class="container">
    <!-- Section header -->
    <div class="mb-12">
      <span class="text-accent-primary font-mono text-sm">01</span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2">Sobre mí</h2>
    </div>

    <!-- Profile and intro -->
    <div class="grid md:grid-cols-[auto_1fr] gap-12 items-start mb-12">
      <!-- Profile Image -->
      <div class="flex justify-center md:justify-start">
        <div class="relative">
          <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden border-4 border-border-subtle">
            <img
              src="/images/profile.jpg"
              alt="Foto de perfil"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-2 -right-2 w-12 h-12 rounded-full bg-accent-primary flex items-center justify-center">
            <span class="text-white font-bold text-lg">H</span>
          </div>
        </div>
      </div>

      <!-- Text content -->
      <div class="space-y-6">
        <p class="text-text-secondary text-lg leading-relaxed">
          {profile.about}
        </p>
        <p class="text-text-secondary leading-relaxed">
          Mi combinación única de gestión estratégica + implementación técnica + desarrollo de software
          me permite abordar problemas desde múltiples ángulos. No solo despacho tickets — diseño soluciones
          que impactan el negocio.
        </p>
      </div>
    </div>

    <!-- Stats/Highlights -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="card text-center">
        <div class="text-accent-primary font-heading text-3xl font-bold mb-1">3+</div>
        <div class="text-text-secondary text-xs">Años como Coordinador de TI</div>
      </div>
      <div class="card text-center">
        <div class="text-accent-secondary font-heading text-3xl font-bold mb-1">5+</div>
        <div class="text-text-secondary text-xs">Proyectos desplegados</div>
      </div>
      <div class="card text-center">
        <div class="text-accent-primary font-heading text-3xl font-bold mb-1">40%</div>
        <div class="text-text-secondary text-xs">Reducción en soporte</div>
      </div>
      <div class="card text-center">
        <div class="text-accent-secondary font-heading text-3xl font-bold mb-1">99.9%</div>
        <div class="text-text-secondary text-xs">Disponibilidad</div>
      </div>
    </div>
  </div>
</section>
