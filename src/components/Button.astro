---
// ============================================================
// BUTTON — Botón reutilizable con variantes
// Variantes: primary (azul sólido), outline (borde azul), ghost
// Uso: <Button href="/cv.pdf" variant="primary">Descargar CV</Button>
// ============================================================
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
  target?: string;
  rel?: string;
}

const { href, variant = 'primary', class: className = '', target, rel } = Astro.props;

// Clases base + variante
const base = 'inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-medium text-sm transition-all duration-200 cursor-pointer';
const variants: Record<string, string> = {
  primary: 'bg-blue-500 text-white hover:bg-blue-400 shadow-lg shadow-blue-500/20',
  outline: 'border border-blue-500/40 text-blue-400 hover:bg-blue-500/10 hover:border-blue-400',
  ghost:   'text-slate-400 hover:text-slate-200 hover:bg-slate-800',
};
---

{href ? (
  <a href={href} class={`${base} ${variants[variant]} ${className}`} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button class={`${base} ${variants[variant]} ${className}`}>
    <slot />
  </button>
)}
