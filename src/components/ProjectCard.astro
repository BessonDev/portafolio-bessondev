---
// ============================================================
// PROJECT CARD — Tarjeta individual de proyecto de código
// Uso: dentro de ProjectsGrid
// Props: title, description, stack[], githubUrl, demoUrl, category
// ============================================================
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  stack: string[];
  githubUrl?: string;
  demoUrl?: string;
  category?: string;
}

const { title, description, stack, githubUrl, demoUrl, category } = Astro.props;
---

<div
  class="group rounded-2xl border p-6 flex flex-col gap-4 transition-all duration-200 scroll-reveal"
  style="background-color: #0f172a; border-color: #1e293b;"
  onmouseover="this.style.borderColor='#334155'; this.style.backgroundColor='#111827'"
  onmouseout="this.style.borderColor='#1e293b'; this.style.backgroundColor='#0f172a'"
>
  <!-- Categoría -->
  {category && (
    <Tag label={category} variant="emerald" />
  )}

  <!-- Título -->
  <h3 class="font-bold text-lg" style="color: #f8fafc;">{title}</h3>


  <!-- Descripción -->
  <p class="text-sm leading-relaxed flex-1" style="color: #94a3b8;">{description}</p>

  <!-- Stack -->
  <div class="flex flex-wrap gap-1.5">
    {stack.map((tech) => (
      <span class="px-2 py-0.5 rounded-md text-xs font-mono" style="background-color: #1e293b; color: #64748b;">
        {tech}
      </span>
    ))}
  </div>

  <!-- Links -->
  <div class="flex gap-3 pt-1">
    {githubUrl && (
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs font-medium transition-colors"
        style="color: #64748b;"
        onmouseover="this.style.color='#f8fafc'"
        onmouseout="this.style.color='#64748b'"
      >
        <!-- GitHub icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Ver código
      </a>
    )}
    {demoUrl && (
      <a
        href={demoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs font-medium transition-colors"
        style="color: #64748b;"
        onmouseover="this.style.color='#3b82f6'"
        onmouseout="this.style.color='#64748b'"
      >
        <!-- External link icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Demo
      </a>
    )}
  </div>

</div>
