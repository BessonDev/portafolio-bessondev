---
interface Project {
  title: string;
  description: string;
  stack: string[];
  link: string;
  image: string;
  demoUrl?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

// Mapeo de tecnologías: [nombreDevicon, tieneVersionPlain]
const techMap: Record<string, [string, boolean]> = {
  'HTML5': ['html5', true],
  'HTML': ['html5', true],
  'CSS3': ['css3', true],
  'CSS': ['css3', true],
  'JavaScript': ['javascript', true],
  'JS': ['javascript', true],
  'TypeScript': ['typescript', true],
  'TS': ['typescript', true],
  'Python': ['python', true],
  'Flask': ['flask', false],     // Flask no tiene plain, usar original
  'Django': ['django', true],
  'Node.js': ['nodejs', true],
  'Node': ['nodejs', true],
  'Next.js': ['nextjs', true],
  'Next': ['nextjs', true],
  'Astro': ['astro', true],
  'React': ['react', true],
  'Vue': ['vue', true],
  'TailwindCSS': ['tailwindcss', false],  // Tailwind no tiene plain
  'Tailwind': ['tailwindcss', false],
  'Bootstrap': ['bootstrap', true],
  'PostgreSQL': ['postgresql', true],
  'Postgres': ['postgresql', true],
  'MySQL': ['mysql', true],
  'SQLite': ['sqlite', true],
  'PHP': ['php', true],
  'Laravel': ['laravel', true],
};

// Función para obtener el icono de Devicon
function getDeviconUrl(tech: string): string {
  const mapped = techMap[tech];
  if (!mapped) {
    // Si no está en el mapa, intentar con el nombre tal cual
    return `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${tech.toLowerCase()}/${tech.toLowerCase()}-plain.svg`;
  }
  
  const [iconName, hasPlain] = mapped;
  const version = hasPlain ? 'plain' : 'original';
  return `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${iconName}/${iconName}-${version}.svg`;
}
---

