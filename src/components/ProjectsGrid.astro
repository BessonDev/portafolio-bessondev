---
interface Project {
  title: string;
  description: string;
  stack: string[];
  link: string;
  image: string;
  images?: string[];
  demoUrl?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

// Mapeo de tecnologías: [nombreDevicon, tieneVersionPlain]
const techMap: Record<string, [string, boolean]> = {
  'HTML5': ['html5', true],
  'HTML': ['html5', true],
  'CSS3': ['css3', true],
  'CSS': ['css3', true],
  'JavaScript': ['javascript', true],
  'JS': ['javascript', true],
  'TypeScript': ['typescript', true],
  'TS': ['typescript', true],
  'Python': ['python', true],
  'Flask': ['flask', false],     // Flask no tiene plain, usar original
  'Django': ['django', true],
  'Node.js': ['nodejs', true],
  'Node': ['nodejs', true],
  'Next.js': ['nextjs', true],
  'Next': ['nextjs', true],
  'Astro': ['astro', true],
  'React': ['react', true],
  'Vue': ['vue', true],
  'TailwindCSS': ['tailwindcss', false],  // Tailwind no tiene plain
  'Tailwind': ['tailwindcss', false],
  'Bootstrap': ['bootstrap', true],
  'PostgreSQL': ['postgresql', true],
  'Postgres': ['postgresql', true],
  'MySQL': ['mysql', true],
  'SQLite': ['sqlite', true],
  'PHP': ['php', true],
  'Laravel': ['laravel', true],
};

// Función para obtener el icono de Devicon
function getDeviconUrl(tech: string): string {
  const mapped = techMap[tech];
  if (!mapped) {
    // Si no está en el mapa, intentar con el nombre tal cual
    return `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${tech.toLowerCase()}/${tech.toLowerCase()}-plain.svg`;
  }
  
  const [iconName, hasPlain] = mapped;
  const version = hasPlain ? 'plain' : 'original';
  return `https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${iconName}/${iconName}-${version}.svg`;
}
---

<section id="proyectos" class="py-12 md:py-16 bg-slate-900/50">
  <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-widest mb-3 text-center" style="color: #3b82f6;">Proyectos de Código</p>
    <h2 class="text-3xl font-bold text-white mb-12 text-center scroll-reveal">Proyectos</h2>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, projectIndex) => (
        <div class="group bg-slate-800 border border-slate-700 rounded-2xl overflow-hidden hover:border-blue-500/50 transition-all duration-300 scroll-reveal">
          <!-- Image Carousel -->
          <div class="aspect-video overflow-hidden bg-slate-900 relative" data-carousel-project={projectIndex}>
            {(project.images && project.images.length > 0) ? (
              <>
                <img src={project.image} alt={project.title} class="project-main-image w-full h-full object-cover transition-transform duration-500" data-current="0" />
                {project.images.map((img, i) => (
                  <img src={img} alt={`${project.title} - ${i + 2}`} class="hidden w-full h-full object-cover" data-index={i + 1} />
                ))}
                {/* Navigation Arrows */}
                {project.images.length > 0 && (
                  <>
                    <button class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/70" data-project={projectIndex}>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <button class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/50 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/70" data-project={projectIndex}>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                    {/* Dots indicator */}
                    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1">
                      <span class="w-2 h-2 rounded-full bg-white/80 carousel-dot" data-index="0"></span>
                      {project.images.map((_, i) => (
                        <span class="w-2 h-2 rounded-full bg-white/40 carousel-dot" data-index={i + 1}></span>
                      ))}
                    </div>
                  </>
                )}
              </>
            ) : (
              <img src={project.image} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            )}
          </div>
          <div class="px-6 py-4">
            <h3 class="text-xl font-semibold text-white mb-2">{project.title}</h3>
            <p class="text-slate-400 text-sm mb-4 line-clamp-3">{project.description}</p>
            
<!-- Tech Stack Icons + Demo Button (inline) -->
            <div class="flex flex-wrap gap-2 items-center">
              {project.stack.map((s) => (
                <img 
                  src={getDeviconUrl(s)} 
                  alt={s} 
                  title={s}
                  class="w-5 h-5 object-contain"
                  style="filter: brightness(0) invert(1); opacity: 0.6; transition: opacity 0.2s;"
                  onmouseover="this.style.opacity='1'"
                  onmouseout="this.style.opacity='0.6'"
                  loading="lazy"
                />
              ))}
              {project.demoUrl && (
                <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-600 text-white hover:bg-blue-500 transition-colors ml-auto">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Demo
                </a>
              )}
            </div>
            
</div>
          </div>
        </div>
      ))}
           
    </div>

    
  </div>
</section>

<script>
  // Carousel functionality
  document.querySelectorAll('[data-carousel-project]').forEach((carousel) => {
    const projectIndex = carousel.getAttribute('data-carousel-project');
    const images = carousel.querySelectorAll('img');
    const totalImages = images.length;
    
    if (totalImages <= 1) return;
    
    let currentIndex = 0;
    
    // Get navigation buttons
    const prevBtn = carousel.querySelector('.carousel-prev');
    const nextBtn = carousel.querySelector('.carousel-next');
    const dots = carousel.querySelectorAll('.carousel-dot');
    
    function showImage(index) {
      images.forEach((img, i) => {
        img.classList.toggle('hidden', i !== index);
        img.classList.toggle('block', i === index);
      });
      
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-white/80', i === index);
        dot.classList.toggle('bg-white/40', i !== index);
      });
      
      currentIndex = index;
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const newIndex = currentIndex === 0 ? totalImages - 1 : currentIndex - 1;
        showImage(newIndex);
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const newIndex = currentIndex === totalImages - 1 ? 0 : currentIndex + 1;
        showImage(newIndex);
      });
    }
    
    dots.forEach((dot, i) => {
      dot.addEventListener('click', (e) => {
        e.stopPropagation();
        showImage(i);
      });
    });
  });
</script>
