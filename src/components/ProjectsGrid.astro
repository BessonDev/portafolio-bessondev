---
interface Project {
  title: string;
  description: string;
  stack: string[];
  link: string;
  image: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---


<section id="proyectos" class="py-20 bg-slate-900/50">
  <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-bold uppercase tracking-widest mb-3 text-center" style="color: #3b82f6;">Proyectos de Código</p>
    <h2 class="text-3xl font-bold text-white mb-12 text-center scroll-reveal">Proyectos</h2>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <div class="group bg-secondary border border-border-subtle rounded-2xl overflow-hidden hover:border-blue-500/50 transition-all duration-300 scroll-reveal">
          <div class="aspect-video overflow-hidden bg-slate-800">
            <img src={project.image} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-white mb-2">{project.title}</h3>
            <p class="text-slate-400 text-sm mb-4 line-clamp-2">{project.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.stack.map((s) => (
                <span class="text-[10px] uppercase tracking-wider font-bold text-slate-500">{s}</span>
              ))}
            </div>
            <a href={project.link} target="_blank" class="inline-flex items-center gap-2 text-blue-400 text-sm font-medium hover:text-blue-300 transition-colors">
              Ver en GitHub
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      ))}
          
    </div>

    
  </div>
</section>
