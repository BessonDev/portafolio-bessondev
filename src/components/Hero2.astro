---
// ============================================================
// HERO — Primera sección (above the fold)
// Contiene: nombre, título, elevator pitch, CTAs, badge "disponible"
// ============================================================
import Button from './Button.astro';
---

<section id="hero" class="min-h-screen flex items-center pt-16 pb-20">
  <div class="max-w-5xl mx-auto px-6 w-full">

    <!-- Badge "disponible para oportunidades" -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border text-xs font-medium mb-8"
         style="background-color: rgba(16, 185, 129, 0.08); border-color: rgba(16, 185, 129, 0.25); color: #10b981;">
      <!-- Punto verde parpadeante -->
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background-color: #10b981;"></span>
        <span class="relative inline-flex rounded-full h-2 w-2" style="background-color: #10b981;"></span>
      </span>
      Disponible para nuevas oportunidades
    </div>

    <!-- Título principal -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-4" style="color: #f8fafc;">
      Harold Besson
    </h1>

    <!-- Subtítulo con acento de color -->
    <p class="text-xl sm:text-2xl font-semibold mb-6" style="color: #3b82f6;">
      Ingeniero de Sistemas
      <span style="color: #64748b;"> · </span>
      <span style="color: #10b981;">Arquitecto de Infraestructura</span>
      <span style="color: #64748b;"> · </span>
      Dev Full-Stack
    </p>

    <!-- Elevator Pitch -->
    <p class="text-lg max-w-2xl leading-relaxed mb-10" style="color: #cbd5e1;">
      Especialista en transformar infraestructuras complejas en entornos eficientes y escalables.
      Mi enfoque une la <strong style="color: #f8fafc;">gestión estratégica de TI</strong> con el
      <strong style="color: #f8fafc;">desarrollo de soluciones a medida</strong> en Python, PHP y más.
      Coordiné equipos técnicos, desplegué arquitecturas en Docker y construí plataformas web desde cero.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4 mb-16">
      <Button href="#experiencia" variant="primary">
        <!-- Icono flecha abajo -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
        Ver mi trabajo
      </Button>
      <Button href="#contacto" variant="outline">
        Contáctame
      </Button>
    </div>

    <!-- Stats / Badges rápidos -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {[
        { label: 'Infraestructura', value: 'Linux + Docker' },
        { label: 'Desarrollo', value: 'Full-Stack' },
        { label: 'Gestión', value: 'Coordinador TI' },
        { label: 'Educación', value: 'Facilitador' },
      ].map((stat) => (
        <div class="rounded-xl p-4 border" style="background-color: #0f172a; border-color: #1e293b;">
          <p class="text-xs font-medium mb-1" style="color: #64748b;">{stat.label}</p>
          <p class="text-sm font-semibold" style="color: #f8fafc;">{stat.value}</p>
        </div>
      ))}
    </div>

  </div>
</section>
