---
interface Props {
  bio: string;
}

const { bio } = Astro.props;
---

<section id="sobre-mi" class="py-20 bg-slate-900/50">
  <div class="max-w-4xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="relative group scroll-reveal">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-emerald-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative aspect-square rounded-2xl overflow-hidden bg-slate-800 border border-slate-700">
          <img src="/profile.jpg" alt="Harold" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" />
        </div>
      </div>
      
      <div class="space-y-6 scroll-reveal">
        <h2 class="text-3xl font-bold text-white">Sobre Mí</h2>
        <div class="text-slate-400 leading-relaxed text-lg space-y-4">
          {bio.split('\n').map(paragraph => <p>{paragraph}</p>)}
        </div>
        <div class="pt-4">
          <a href="/cv.pdf" class="inline-flex items-center gap-2 px-6 py-2 rounded-lg font-medium transition-all duration-200 bg-slate-800 text-slate-200 hover:bg-slate-700 border border-slate-700">
            Descargar CV
          </a>
        </div>
      </div>
    </div>
  </div>
</section>