---
// ============================================================
// INDEX — Página principal del portafolio
// Composición de secciones en orden estratégico:
// Hero → Sobre Mí → Experiencia (Case Studies) → Stack → Proyectos → Liderazgo → Contacto
// ============================================================
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SobreMi from '../components/SobreMi.astro';
import CaseStudy from '../components/CaseStudy.astro';
import TechTable from '../components/TechTable.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import Leadership from '../components/Leadership.astro';
import Footer from '../components/Footer.astro';

const projects = [
    {
    title: "Sistema de Pedidos Web 📲",  
    description: "Menu interactivo web para restaurantes, con sistema de carrito de compras, pedidos via whatsapp y precios a la tasa del dia.",
    stack: ["Astro", "TailwindCSS", "HTML", "CSS"],
    link: "https://github.com/bessondev/empanadas-elgordito",
    image: "/images/empanadas2.webp",
    images: [                        
      "/images/empanadas.webp",                                                                                                                                             
       ], 
    demoUrl: "https://empanadas.bessondev.com"
  },
    {
    title: "Linsbsay Inventory 📦",  
    description: "Sistema de inventario para empresas, con control de stock, gestion de productos y reportes en tiempo real. 100% offline.",
    stack: ["Python", "Flask", "SQLite", "HTML", "CSS", "Bootstrap"],
    link: "https://github.com/bessondev/sistema-inventario",
    image: "/images/linsbsay_login.webp",
    images: [                                                                        
         "/images/linsbsay_dash.webp",
         "/images/linsbsay_listar.webp",
         "/images/linsbsay_report.webp"                                                                           
       ], 
    // demoUrl: "https://memorial.bessondev.com"
  },
  {
    title: "Memorial App 📠",  
    description: "Plataforma de gestión de funerarias y control de afiliados. Con precios actualizados a tasa dinamica.",
    stack: ["Next.js", "SQLite", "TailwindCSS", "HTML", "CSS"],
    link: "https://github.com/bessondev/memorial-app",
    image: "/images/memorial_dash_shot.webp",
    images: [
      "/images/memorial_pagos.webp",
       ], 
    demoUrl: "https://memorial.bessondev.com"
  },
  {
    title: "Hotel Plan 🏨",
    description: "Plataforma web para la gestión hotelera, control de habitaciones, reportes, movimientos de turno y precios.",
    stack: ["Node.js", "SQLite", "TailwindCSS", "HTML", "CSS"],
    link: "https://github.com/bessondev/hotel-local-app",
    image: "/images/hotel_dash_shot.webp",
    images: [                                                                                                                                                                   
      "/images/hotel_turno.webp",
       ], 
    // demoUrl: "https://hotelplan.bessondev.com"
  },
  {
    title: "Brillary Shop 🛒",
    description: "Tienda virtual con integración a whatsapp, modulo de administración y precios actualizados a tasa del dia.",
    stack: ["Astro", "PostgreSQL", "TailwindCSS", "HTML", "CSS", "JavaScript"],
    link: "https://github.com/bessondev/brillary-eccomerce",
    image: "/images/brillary_shot.webp",
    images: [                                                                                                                                                                      
       ], 
    demoUrl: "https://www.brillaryshop.bessondev.com",
  }
];

---

<Layout>
  <Header />

  <main>
    <!-- 1. Hero: primera impresión -->
    <Hero name="Harold Besson" title="Arquitecto de Infraestructura & Desarrollador de Software" 
    pitch="Ingeniero de sistemas con experiencia en gestión estratégica de TI." />  
    <!-- 2. Sobre Mí: contexto personal y diferenciadores -->

    <section id="sobre-mi" class="py-12 md:py-16">
      <div class="max-w-5xl mx-auto px-6">

        <div class="mb-8 md:mb-10 scroll-reveal">
            <SobreMi />
        </div>
      </div>
    </section>

    <!-- 3. Experiencia: Casos de Éxito -->
    <section id="experiencia" class="py-12 md:py-16">
      <div class="max-w-5xl mx-auto px-6">

        <div class="mb-10 scroll-reveal">
          <p class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #3b82f6;">Experiencia</p>
          <h2 class="text-3xl md:text-4xl font-bold" style="color: #f8fafc;">Casos de Éxito</h2>
          <p class="mt-3 text-sm" style="color: #64748b;">Click en cada caso para ver el detalle completo.</p>
        </div>

        <!-- Caso 1: Infraestructura -->
        <div class="space-y-5">
          <CaseStudy
            title="Arquitectura de Servicios Centralizados y Soberanía de Datos"
            category="Infraestructura"
            problem="La organización dependía de sistemas dispersos, con baja seguridad y dificultad para el soporte técnico, operaban de manera informal y sin métricas, ni documentación de incidencias o solicitudes. Lo que generaba tiempos de respuesta lentos en la resolución de problemas tecnicos y falta de seguimiento, asi como una gran cantidad de trabajo manual y repetitivo cada vez que un usuario requería soporte técnico. De la misma forma no se contaba con un control centralizado de la infraestructura de TI, lo que dificultaba el monitoreo y la administración de los sistemas."
            solution="Diseñé e implementé desde cero un ecosistema basado en infraestructura local con servidores físicos. Desplegué GLPI para la transición de soporte informal a una mesa de ayuda profesional con trazabilidad total. Implementé Nextcloud como nube privada para garantizar soberanía de datos y optimicé la conectividad con auditoría completa de red y puntos de acceso bajo una topología estandarizada y segura."
            impact={[
              "Reducción del 40% en el tiempo promedio de resolución de incidencias en la institución",
              "Centralización del 100% de la documentación técnica organizacional y privacidad de los datos",
              "Ahorro mensual significativo en licencias de almacenamiento en la nube",
              "Disponibilidad de infraestructura del 99.9% mediante aislamiento de contenedores Docker",
              "Metricas detalladas para la toma de decisiones en el area de TI",
              "Informes de inventario de activos y solicitudes en tiempo real",
              "Mejora de la comunicación entre el area de TI y los usuarios.",
              "Reduccion de un 90% de solicitudes e incidencias sin resolver.",
              "Documentación técnica centralizada y accesible para todo el personal",
            ]}
            tags={["Linux", "Docker", "GLPI", "Nextcloud", "Redes Estructuradas", "Seguridad Informática", "Virtualización", "Acceso Remoto"]}
            image="/images/diagrama_fcyt.webp"
            gallery={[
              "/images/screen/glpi_dash.webp",
              "/images/screen/omv_dash.webp",
              "/images/screen/multi_pc.webp",
            ]}
          />

          <!-- Caso 2: Plataforma Educativa -->
          <CaseStudy
            title="Plataforma Integral de Gestión para Cursos y Talleres"
            category="Desarrollo Full-Stack"
            problem="La gestión de inscripciones, asignación de docentes y seguimiento de historial académico se realizaba de forma manual, las personas tenian que dirigirse a la institución para realizar procesos y obtener información, lo que generaba tareas repetitivas, pérdida de tiempo y una atención al usuario deficiente. Todo esto sumado a la falta de organización y control de la información, lo que provocaba errores en la data, lentitud en los procesos administrativos y un seguimiento altamente complejo y poco funcional."
            solution="Desarrollé una plataforma web que centraliza la gestión académica. El sistema incluye un panel administrativo para el control de oferta y facilitadores, un módulo de inscripción intuitivo y accesible con validación en tiempo real y una arquitectura optimizada en MySQL para garantizar la integridad de los datos."
            impact={[
              "Automatización total del proceso de inscripción, reduciendo el trabajo manual en un 75%",
              "Acceso instantáneo a reportes de rendimiento y asistencia para coordinadores",
              "Interfaz responsiva que permite inscribirse desde cualquier dispositivo móvil",
              "Acceso a información actualizada de oferta académica, facilitadores y horarios en tiempo real.",
              "Eliminación de errores de data causados por duplicación manual.",
            ]}
            tags={["PHP", "MySQL", "JavaScript", "HTML5", "CSS3", "Full-Stack"]}
            image="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=400&q=80"
            gallery={[
              "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=400&q=80",
              "https://images.unsplash.com/photo-1501504905252-473c47e087f8?w=400&q=80",
              "https://images.unsplash.com/photo-1542744094-3a31f272c490?w=400&q=80",
            ]}
          />
        </div>

      </div>
    </section>

    <!-- 4. Stack Tecnológico -->
    <TechTable />

    <!-- 5. Proyectos de Código -->
    <ProjectsGrid projects={projects} /> 
    
    <!-- 6. Liderazgo y Mentoría (diferenciador) -->
    <Leadership />
  </main>

  <!-- 7. Footer + Contacto -->
  <Footer />
</Layout>
